# Local Development Environment
# Copy this file to .env.local before running:
#   npm run docker:restart   (build + start the local Docker container)
#   npm test                 (suites that target the local container)
#
# .env.local is gitignored — keep your real secrets there, never commit it.

# ============================================
# REQUIRED VARIABLES
# ============================================

# URL the app advertises (must match host:DOCKER_PORT below)
MOIRA_HOST=localhost:8080

# Better Auth secret for session encryption (generate your own 32+ char value)
BETTER_AUTH_SECRET=change-me-local-dev-secret-32-chars-min

# Database path (bind-mounted to the host)
DB_PATH=./data/moira.db

# ============================================
# ADMIN CONFIGURATION (bootstrap admin account)
# ============================================

ADMIN_EMAIL=admin@moira.local
ADMIN_PASSWORD=AdminLocal123

# ============================================
# LOCAL DOCKER CONTAINER
# ============================================

# Host port for the local container (npm run docker:restart reads these)
DOCKER_PORT=8080
DOCKER_IMAGE_NAME=moira-local
DOCKER_CONTAINER_NAME=moira-local

# Internal service ports (Docker internal — usually leave as-is)
WEB_BACKEND_PORT=4201
WEB_FRONTEND_PORT=4200
MCP_PORT=4202

# ============================================
# EMAIL (console = print to logs, no real email)
# ============================================

EMAIL_PROVIDER=console
EMAIL_FROM=noreply@moira.local
EMAIL_FROM_NAME=MCP Moira Local
CONTACT_EMAIL=support@moira.local

# ============================================
# TELEGRAM ENCRYPTION (64 hex chars = 32 bytes; replace for real use)
# ============================================

TELEGRAM_ENCRYPTION_KEY=a1b2c3d4e5f6789012345678901234567890abcdef1234567890abcdef123456

# ============================================
# LOGGING & DEVELOPMENT
# ============================================

LOG_LEVEL=info
LOG_SQL=false
DISABLE_RATE_LIMIT=true
