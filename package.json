{
  "name": "mcp-moira",
  "version": "0.3.2",
  "description": "Agent Workflow Engine for AI agents with professional Web UI dashboard",
  "main": "dist/server.js",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "mcp-moira": "./dist/server.js",
    "moira-cli": "./dist/cli.js"
  },
  "scripts": {
    "test": "testfold unit workflow integration api e2e mcp-tools -e local",
    "test:unit": "testfold unit",
    "test:workflow": "testfold workflow",
    "test:integration": "testfold integration",
    "test:api": "testfold api -e local",
    "test:mcp-tools": "testfold mcp-tools -e local",
    "test:e2e": "testfold e2e -e local",
    "test:remote": "testfold unit workflow integration api e2e mcp-tools -e remote",
    "test:api:remote": "testfold api -e remote",
    "test:mcp-tools:remote": "testfold mcp-tools -e remote",
    "test:e2e:remote": "testfold e2e -e remote",
    "docker:restart": "./scripts/docker-build-and-run.sh --local",
    "docker:restart:remote": "./scripts/docker-build-and-run.sh --remote",
    "docker:stop": ". ./.env.local && docker stop ${DOCKER_CONTAINER_NAME} || true",
    "fix": "eslint . --fix && prettier --write ."
  },
  "lint-staged": {
    "*.{js,ts,tsx,astro}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,mdx,css,yml,yaml}": "prettier --write"
  },
  "keywords": [
    "mcp",
    "workflow",
    "ai",
    "automation",
    "json"
  ],
  "author": "mcp-moira team",
  "license": "Apache-2.0",
