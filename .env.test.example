# Test Environment Configuration
# Used by testfold and Jest for local test execution
# Copy to .env.test: cp .env.test.example .env.test

# ============================================
# REQUIRED VARIABLES
# ============================================

# Host configuration (test-appropriate, not used for connections)
MOIRA_HOST=localhost:3031

# Better Auth secret for session encryption (test-only)
BETTER_AUTH_SECRET=test-secret-for-local-testing-only

# Database path (overridden per-suite, but needed for env loading)
DB_PATH=./data/moira.db

# ============================================
# ADMIN CONFIGURATION
# ============================================

ADMIN_EMAIL=admin@moira.local
ADMIN_PASSWORD=AdminTest123

# ============================================
# SERVER PORTS
# ============================================

DOCKER_PORT=3031
WEB_BACKEND_PORT=4201
WEB_FRONTEND_PORT=4200
MCP_PORT=4202

DOCKER_IMAGE_NAME=mcp-moira-dev
DOCKER_CONTAINER_NAME=mcp-moira-dev

# ============================================
# EMAIL (disabled for tests)
# ============================================

EMAIL_PROVIDER=console
EMAIL_FROM=noreply@test.local
EMAIL_FROM_NAME=MCP Moira Test
CONTACT_EMAIL=support@moira.local

# ============================================
# TELEGRAM ENCRYPTION
# ============================================

# Test encryption key (64 hex chars = 32 bytes)
TELEGRAM_ENCRYPTION_KEY=a1b2c3d4e5f6789012345678901234567890abcdef1234567890abcdef123456

# ============================================
# LOGGING & DEVELOPMENT
# ============================================

LOG_LEVEL=warn
LOG_SQL=false
DISABLE_RATE_LIMIT=true

# SQLite journal mode for tests
SQLITE_JOURNAL_MODE=DELETE
