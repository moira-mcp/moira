{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "ES2022",
    "target": "ES2022",
    "moduleResolution": "Node16",
    "rootDir": ".",
    // Compiled files go to tests/dist/ (if ever compiled)
    // ts-jest compiles in-memory due to noEmit: true
    "outDir": "./dist",
    "noEmit": true,
    "skipLibCheck": true,
    "jsx": "react-jsx"
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["dist", "node_modules"]
}
