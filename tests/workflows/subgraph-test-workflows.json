        },
        "outputMapping": {
          "result": "finalResult"
        },
        "connections": {
          "success": "end"
        }
      },
      {
        "type": "end",
        "id": "end",
        "finalOutput": [
          "finalResult",
          "level",
          "data"
        ]
      }
    ]
  },
  {
    "slug": "subgraph-middle-level",
