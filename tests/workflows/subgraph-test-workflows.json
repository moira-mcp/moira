            "data": {
              "description": "Root data passed through levels",
              "value": "root-data"
            }
          }
        },
        "connections": {
          "default": "subgraph"
        }
      },
      {
        "type": "subgraph",
        "id": "subgraph",
        "graphId": "subgraph-middle-level",
        "inputMapping": {
          "level": "level",
