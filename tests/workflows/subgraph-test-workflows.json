        "connections": {
          "default": "condition"
        }
      },
      {
        "type": "condition",
        "id": "condition",
        "condition": {
          "operator": "lt",
          "left": {
            "contextPath": "level"
          },
          "right": 3
        },
        "connections": {
          "true": "subgraph",
          "false": "end"
        }
      },
      {
        "type": "subgraph",
        "id": "subgraph",
