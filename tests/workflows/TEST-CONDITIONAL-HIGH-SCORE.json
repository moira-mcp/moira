{
  "slug": "TEST-CONDITIONAL-HIGH-SCORE",
  "metadata": {
    "name": "TEST-CONDITIONAL-HIGH-SCORE",
    "version": "1.0.0",
    "description": "Test conditional then branch - migrated from old test"
  },
  "nodes": [
    {
      "type": "start",
      "id": "start",
      "connections": {
        "default": "get-score"
      }
    },
    {
      "type": "agent-directive",
      "id": "get-score",
      "directive": "Enter test score",
      "completionCondition": "Score provided",
      "connections": {
        "success": "score-check"
      },
      "inputSchema": {
        "type": "object",
        "properties": {
          "score": {
            "type": "number"
          }
        },
        "required": [
          "score"
        ]
      }
    },
    {
      "type": "condition",
      "id": "score-check",
      "condition": {
        "operator": "gt",
        "left": {
          "contextPath": "score"
        },
        "right": 70
      },
      "connections": {
        "true": "congratulate",
        "false": "encourage"
      }
    },
    {
      "type": "agent-directive",
      "id": "congratulate",
      "directive": "Congratulate on excellent score",
      "completionCondition": "Congratulations delivered",
      "connections": {
        "success": "end"
      }
    },
    {
      "type": "agent-directive",
      "id": "encourage",
      "directive": "Try again - you can do better",
      "completionCondition": "Encouragement given",
      "connections": {
        "success": "end"
      }
    },
    {
      "type": "end",
      "id": "end",
      "finalOutput": [
        "score"
      ]
    }
  ]
}
