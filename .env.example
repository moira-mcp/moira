# MCP Moira Environment Configuration
#
# Self-host quickstart (pull-first — no source build needed):
#   cp .env.example .env
#   docker compose up -d        # pulls ghcr.io/moira-mcp/moira:latest
#   open http://localhost:8080
#
# For a LOCALHOST run you can leave this file UNCHANGED — the defaults below work
# as-is, and the three secrets are auto-generated on first boot (see below).
#
# For a REAL host/port you MUST edit the three host-dependent vars together so
# their ports stay consistent: MOIRA_HOST, MOIRA_PORT, STATIC_ARTIFACTS_DOMAIN.

# ============================================
# REQUIRED VARIABLES (host-dependent — keep ports consistent)
# ============================================

# Public host (REQUIRED). Host only, protocol auto-detected: localhost=http, else=https.
# Must match MOIRA_PORT below and STATIC_ARTIFACTS_DOMAIN. Examples: localhost:8080, moira.example.com
MOIRA_HOST=localhost:8080

# Deployment mode: "self-host" (default) or "saas".
# - self-host: single-user / private-team install. No open registration, no
#   email-verification gate, no legal-consent requirement; missing secrets are
#   auto-generated on first start.
# - saas: hosted multi-tenant. Enforces email verification, legal consents,
#   open registration, verification emails. Required secrets must be provided.
DEPLOYMENT_MODE=self-host

# Cross-origin allowlist (optional). Comma-separated list of origins permitted
# to make cross-origin browser requests to the API. The app's own origin
# (derived from MOIRA_HOST) and localhost origins are always allowed, so this is
# only needed when the frontend is served from a different origin than the API.
# Example: CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

# Static artifacts domain (REQUIRED — startup aborts if empty; NOT auto-generated).
# Where user HTML artifacts are served. Keep its port consistent with MOIRA_HOST/MOIRA_PORT.
# Examples: static.localhost:8080 (local), static.example.com (deployed)
# Artifacts are served ONLY on per-artifact subdomains {uuid}.{STATIC_ARTIFACTS_DOMAIN}.
# Deployed domains require the *.{STATIC_ARTIFACTS_DOMAIN} wildcard TLS cert (DNS-01);
# localhost works over HTTP via *.static.localhost.
STATIC_ARTIFACTS_DOMAIN=static.localhost:8080

# ============================================
# AUTO-GENERATED SECRETS (self-host: leave EMPTY)
# ============================================
# In self-host mode (DEPLOYMENT_MODE=self-host) these three are auto-generated on
# first boot and persisted to <data-dir>/.secrets.env — leave them EMPTY and do
# NOT run openssl by hand. (In saas mode they are required and must be provided.)

# Session encryption key. Leave empty → generated on first boot (self-host).
BETTER_AUTH_SECRET=

# Database path (optional, has fallback)
# Default: ./data/moira.db
DB_PATH=./data/moira.db

# ============================================
# ADMIN CONFIGURATION
# ============================================

# Admin user credentials.
# self-host: leave ADMIN_PASSWORD EMPTY → a strong password is auto-generated on
# first boot and printed to the container logs ONCE (record it, then log in as
# ADMIN_EMAIL). Set a value here only if you want to choose the password yourself.
ADMIN_EMAIL=admin@moira.local
ADMIN_PASSWORD=

# ============================================
# SERVER PORTS
# ============================================

# Host port exposed by docker-compose (maps to container nginx :80).
# Must match the port in MOIRA_HOST / STATIC_ARTIFACTS_DOMAIN above.
MOIRA_PORT=8080

# Internal service ports are fixed inside the image and wired to nginx
# (MCP :3000, web-backend :3001) — no need to configure them here.

# ============================================
# OPTIONAL: Workflow catalog directories
# ============================================
# The bundled workflow catalog is loaded from ./workflows/production by default.
# To ALSO load your own private flows, set WORKFLOWS_DIRS to a colon-separated list
# of catalog base directories; each must contain a flows/<uuid>.json layout. They are
# merged and de-duplicated by (owner, slug) — a LATER directory overrides an earlier
# one on a collision, so a directory listed last extends or shadows the bundled one.
# Unset → just the bundled ./workflows/production.
# Example: WORKFLOWS_DIRS=./workflows/production:./my-private-workflows/production
# WORKFLOWS_DIRS=

# ============================================
# OPTIONAL: OAuth Providers (social login)
# ============================================
# Social login (GitHub/Google buttons) is DISABLED in self-host
# (DEPLOYMENT_MODE=self-host) regardless of the values below — it is a saas-only
# feature. Self-host uses email + password. Setting these has no effect unless
# DEPLOYMENT_MODE=saas.

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# OPTIONAL: Email Service
# ============================================

# Only brevo is supported (no configuration needed)

# Brevo API key (optional - without it, emails go to logs)
BREVO_API_KEY=

# Email sender configuration
EMAIL_FROM=noreply@moira-mcp.com
EMAIL_FROM_NAME=MCP Moira

# ============================================
# OPTIONAL: Telegram Integration
# ============================================

# NOTE: Bot token and chat ID come from user settings (UI), not env vars

# Encryption key for Telegram credentials stored in user settings.
# self-host: leave EMPTY → auto-generated on first boot (persisted to
# <data-dir>/.secrets.env). Do not run openssl by hand.
TELEGRAM_ENCRYPTION_KEY=

# API timeout in milliseconds (default: 30000)
TELEGRAM_API_TIMEOUT=30000

# ============================================
# OPTIONAL: Logging & Development
# ============================================

# Log level: error, warn, info, debug
LOG_LEVEL=info

# Enable SQL query logging
LOG_SQL=false

# Disable rate limiting (development only)
DISABLE_RATE_LIMIT=false
